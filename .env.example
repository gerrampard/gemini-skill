# ── Gemini Skill 环境变量 / Environment Variables ──

# 浏览器可执行文件路径，支持 Chrome / Edge / Chromium（不设则自动检测）
# Browser executable path, supports Chrome / Edge / Chromium (auto-detect if not set)
BROWSER_PATH=

# CDP 远程调试端口
# CDP remote debugging port
BROWSER_DEBUG_PORT=40821

# 浏览器用户数据目录（保持登录态、cookies 等）
# Browser user data directory (persists login session, cookies, etc.)
BROWSER_USER_DATA_DIR=

# 是否无头模式（true / false）
# Headless mode (true / false)
BROWSER_HEADLESS=false

# CDP 协议超时时间（毫秒）
# CDP protocol timeout (milliseconds)
BROWSER_PROTOCOL_TIMEOUT=60000

# 截图 / 图片输出目录
# Screenshot / image output directory
OUTPUT_DIR=

# Atlas Cloud OpenAI 兼容 API Base URL
# Atlas Cloud OpenAI-compatible API Base URL
ATLAS_BASE_URL=https://api.atlascloud.ai/v1

# Atlas Cloud API Key
# Put the real key into .env.development or local environment variables
ATLAS_API_KEY=

# Atlas Cloud 默认模型
# Atlas Cloud default model
ATLAS_MODEL=openai/gpt-4o-mini

# Atlas Cloud 请求超时（毫秒）
# Atlas Cloud request timeout (milliseconds)
ATLAS_REQUEST_TIMEOUT_MS=60000
